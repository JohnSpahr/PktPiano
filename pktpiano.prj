"but","playBtn",1010,136,0,12,24,#TRUE#,0,"Play",0,0,0
"Sub object1010()
	recordBtn.Status = 0
	If currentNoteIndex > 0 Then
		Dim i as Integer
		Dim dlay as Integer
		Dim base as Integer
		
		For i = 0 To (currentNoteIndex - 1)
			base = (i * 3) + 1
			
			Sound notes(base), notes(base + 1), notes(base + 2)
			For dlay = 1 To 1000
			Next
		Next
	End If
End Sub"
"but"
1
#TRUE#,#TRUE#,#TRUE#
"obj"
3
"but","c4Btn",1034,0,48,28,32,#TRUE#,0,"C4",0,0,0
"Sub object1034()
	'c4
	If recordBtn.Status = 1 Then
		If currentNoteIndex < 100 Then
			'if recording and less than 100 notes have been recorded
			Dim baseIndex as Integer
			baseIndex = (currentNoteIndex * 3) + 1
			
			'assign next 3 values (frequency, duration, and volume) to next 3 slots in recording array
			notes(baseIndex) = 261
			notes(baseIndex + 1) = durationSlider.Value * 50
			notes(baseIndex + 2) = volumeSlider.Value
			currentNoteIndex = currentNoteIndex + 1
		Else
			'more than 100 notes sin a recording
			MsgBox ~Recording limit reached. Ended recording.~
			recordBtn.Status = 0
		End If
	End If
	
	'play sound (freq, dur, amp)
	Sound 261, durationSlider.Value * 50, volumeSlider.Value
End Sub"
