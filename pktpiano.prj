"Sub Form1003_After()
	'set default slider positions when launched
	durationSlider.Value = 25
	volumeSlider.Value = 32
End Sub"
"Sub Form1003_Event()
	Dim eventType as Integer
	Dim key as String
	eventType = GetEventType()
	
	If eventType = nsbKeyOrButton Then
		key = GetKey()
		If asc(key) = 5 Then 
			MenuDraw ~main~
		End If
	End If
End Sub"
